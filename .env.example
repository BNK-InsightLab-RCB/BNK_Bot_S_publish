APP_ENV=local
APP_PORT=9000

ELASTIC_URL=http://localhost:9200
ELASTIC_USERNAME=
ELASTIC_PASSWORD=
ELASTIC_INDEX=ops_knowledge

SQLITE_PATH=./data/ops_rag.sqlite3
LOCAL_INDEX_PATH=./data/ops_knowledge.json

LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=EMPTY
LLM_MODEL=Qwen/Qwen3-14B-MLX-4bit
LLM_HOST=127.0.0.1
LLM_PORT=8000
LLM_TIMEOUT_SECONDS=60

EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=4
EMBEDDING_CACHE_PATH=./data/embedding_cache.sqlite3
EMBEDDING_FALLBACK_DIM=384

MAX_RETRIEVED_CHUNKS=12
MAX_CONTEXT_CHARS=24000
DEFAULT_USER_ROLE=branch

ENABLE_LLM_SUMMARY=true
ENABLE_LLM_CHAT=false
USE_ELASTICSEARCH_SEARCH=true
ENABLE_THINKING_FOR_SUMMARY=true
ENABLE_THINKING_FOR_CHAT=false

MASK_SOURCE_FOR_BRANCH=true
