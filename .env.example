APP_ENV=local
APP_PORT=9000

ELASTIC_URL=http://localhost:9200
ELASTIC_USERNAME=
ELASTIC_PASSWORD=
ELASTIC_INDEX=ops_knowledge

SQLITE_PATH=./data/ops_rag.sqlite3
LOCAL_INDEX_PATH=./data/ops_knowledge.json

LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=EMPTY
LLM_MODEL=Qwen/Qwen3-14B-MLX-4bit
LLM_HOST=127.0.0.1
LLM_PORT=8000
LLM_TIMEOUT_SECONDS=60

# hash: deterministic local fallback, no model download
# local: sentence-transformers model with hash fallback
# azure_openai: Azure OpenAI text-embedding deployment, recommended for Azure AI Search hybrid mode
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=4
EMBEDDING_CACHE_PATH=./data/embedding_cache.sqlite3
EMBEDDING_FALLBACK_DIM=384

# Azure OpenAI embedding model used by Azure AI Search vector/hybrid retrieval.
# Hackathon/workshop recommended deployment: text-embedding-3-large.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
# Keep 0 for the model default dimension. text-embedding-3-large defaults to 3072.
AZURE_OPENAI_EMBEDDING_DIMENSIONS=0

MAX_RETRIEVED_CHUNKS=12
MAX_CONTEXT_CHARS=24000
DEFAULT_USER_ROLE=branch

ENABLE_LLM_SUMMARY=true
ENABLE_LLM_CHAT=false
USE_ELASTICSEARCH_SEARCH=true
ENABLE_THINKING_FOR_SUMMARY=true
ENABLE_THINKING_FOR_CHAT=false

MASK_SOURCE_FOR_BRANCH=true

# RAG_PROVIDER:
# - local: Elasticsearch/local JSON + optional local Qwen
# - foundry: Azure AI Search retrieval + Microsoft Foundry Responses API when configured
# - multi_agent: Supervisor + Azure Search/Foundry/safety workers, local guardrail fallback
RAG_PROVIDER=local
PUBLIC_REPO_BASE_URL=https://github.com/BNK-InsightLab-RCB/BNK_Bot_S/blob/main

# Azure AI Search for Foundry demo mode.
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX=ops-knowledge
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_API_VERSION=2024-07-01
AZURE_SEARCH_SEMANTIC_CONFIG=ops-semantic-config
AZURE_SEARCH_VECTOR_PROFILE=ops-vector-profile
AZURE_SEARCH_VECTOR_ALGORITHM=ops-hnsw
AZURE_SEARCH_VECTOR_METRIC=cosine
AZURE_SEARCH_CONTENT_FIELD=content
AZURE_SEARCH_VECTOR_FIELD=content_vector
AZURE_SEARCH_ENABLE_VECTOR_QUERY=true
AZURE_SEARCH_HYBRID_K=50
AZURE_SEARCH_VECTOR_WEIGHT=1.0
AZURE_SEARCH_BATCH_SIZE=500

# Azure Blob Storage for drag-and-drop source bundle/file upload.
# Keep credentials only on the backend; never expose them to the browser.
AZURE_STORAGE_ACCOUNT=pjyragstore58
AZURE_STORAGE_CONTAINER=uhihi
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_SAS_TOKEN=
AZURE_STORAGE_UPLOAD_PREFIX=source-drop

# Optional admin token for /api/source-sync/*.
# Set this before exposing the backend as a Foundry OpenAPI tool.
SOURCE_SYNC_ADMIN_TOKEN=

# Microsoft Foundry Responses API.
# If FOUNDRY_API_KEY is empty, the backend tries Azure CLI auth:
# az login
# az account get-access-token --scope https://ai.azure.com/.default
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL_DEPLOYMENT=gpt-5.4
FOUNDRY_API_KEY=

# Use either an existing Foundry Agent name or a project connection ID to Azure AI Search.
FOUNDRY_AGENT_NAME=
FOUNDRY_AI_SEARCH_CONNECTION_ID=
# The app's direct Azure Search path uses vector+semantic hybrid.
# Foundry's Azure AI Search tool needs an integrated vectorizer for vector_* modes,
# so semantic is the portable default for this externally embedded index.
FOUNDRY_AI_SEARCH_QUERY_TYPE=semantic
FOUNDRY_TOP_K=5
FOUNDRY_TIMEOUT_SECONDS=90
FOUNDRY_FORCE_SEARCH_TOOL=true
